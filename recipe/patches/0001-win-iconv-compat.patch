Patch PHP's Windows build to work with conda-forge library names.

conda-forge provides different .lib filenames than what the PHP SDK expects.
Also removes GNU libiconv-specific symbols for compatibility.

diff --git a/ext/iconv/config.w32 b/ext/iconv/config.w32
--- a/ext/iconv/config.w32
+++ b/ext/iconv/config.w32
@@ -9,9 +9,7 @@ if (PHP_ICONV != "no") {

 		EXTENSION("iconv", "iconv.c", PHP_ICONV_SHARED, "/DZEND_ENABLE_STATIC_TSRMLS_CACHE=1");

 		AC_DEFINE("HAVE_ICONV", 1, "Define to 1 if the PHP extension 'iconv' is available.");
-		AC_DEFINE("HAVE_LIBICONV", 1, "Define to 1 if you have the 'libiconv' function.");
-		AC_DEFINE("ICONV_ALIASED_LIBICONV", 1, "Define to 1 if 'iconv()' is aliased to 'libiconv()'.");
-		AC_DEFINE("PHP_ICONV_IMPL", "\"libiconv\"", "The iconv implementation.");
+		AC_DEFINE("PHP_ICONV_IMPL", "\"libc\"", "The iconv implementation.");
 		ADD_FLAG("CFLAGS_ICONV", "/D PHP_ICONV_EXPORTS ");
 		if (!PHP_ICONV_SHARED) {
 			ADD_DEF_FILE("ext\\iconv\\php_iconv.def");
diff --git a/ext/iconv/php_iconv.def b/ext/iconv/php_iconv.def
--- a/ext/iconv/php_iconv.def
+++ b/ext/iconv/php_iconv.def
@@ -1,6 +1 @@
 EXPORTS
-_libiconv_version
-libiconv_close
-libiconv
-libiconv_open
-libiconv_set_relocation_prefix
